{
  "name": "permit-streamliner-evals",
  "version": "0.2.0",
  "description": "Evaluation scenarios for Permit Streamliner (Accelerator 004)",
  "scenarios": [
    {
      "id": "eval-001",
      "input": "I want to build an addition to my house in Sacramento",
      "expected_intent": "project_intake",
      "expected_project_type": "residential_construction",
      "expected_agency": "HCD",
      "tags": ["intake", "residential"]
    },
    {
      "id": "eval-002",
      "input": "How long will my commercial building permit take?",
      "expected_intent": "sla_inquiry",
      "expected_project_type": "commercial_construction",
      "expected_sla_days_min": 45,
      "tags": ["sla", "commercial"]
    },
    {
      "id": "eval-003",
      "input": "What are the fees for an environmental review?",
      "expected_intent": "fee_estimate",
      "expected_project_type": "environmental_review",
      "expected_base_fee": 2000,
      "tags": ["fees", "environmental"]
    },
    {
      "id": "eval-004",
      "input": "I need to demolish an old building downtown",
      "expected_intent": "project_intake",
      "expected_project_type": "demolition",
      "expected_agency": "HCD",
      "tags": ["intake", "demolition"]
    },
    {
      "id": "eval-005",
      "input": "What documents do I need for a commercial construction project?",
      "expected_intent": "requirement_check",
      "expected_project_type": "commercial_construction",
      "expected_checklist_min_items": 5,
      "tags": ["checklist", "commercial"]
    },
    {
      "id": "eval-006",
      "input": "I want to open a small business and need a license",
      "expected_intent": "project_intake",
      "expected_project_type": "business_license",
      "expected_agency": "DCA",
      "tags": ["intake", "business_license"]
    },
    {
      "id": "eval-007",
      "input": "How much extra does it cost to expedite a residential permit?",
      "expected_intent": "fee_estimate",
      "expected_project_type": "residential_construction",
      "tags": ["fees", "expedited"]
    },
    {
      "id": "eval-008",
      "input": "My project is in a coastal zone. What additional requirements are there?",
      "expected_intent": "requirement_check",
      "expected_constraints": ["coastal_zone"],
      "tags": ["checklist", "constraints"]
    }
  ]
}
