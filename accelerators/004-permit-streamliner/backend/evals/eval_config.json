      "expected_route": "residential_permits"
    },
    {
      "id": "eval-010",
      "input": "I want to install solar panels on my commercial building",
      "expected_intent": "project_intake",
      "expected_route": "commercial_permits"
    },
    {
      "id": "eval-011",
