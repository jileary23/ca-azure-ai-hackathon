# -----------------------------------------------------------------------
# LA County Public Defender — Evidence AI
# Copy this file to .env and fill in values for production use.
# Demo/mock mode works without any credentials.
# -----------------------------------------------------------------------

# Set to false to use real Azure services
USE_MOCK_SERVICES=true

# -----------------------------------------------------------------------
# Azure OpenAI (required for production mode)
# Deploy in your Azure Government tenant for CJIS compliance
# -----------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# -----------------------------------------------------------------------
# Azure Video Indexer (required for production mode)
# See: https://learn.microsoft.com/en-us/azure/azure-video-indexer/
# Authentication uses DefaultAzureCredential (Managed Identity)
# -----------------------------------------------------------------------
VIDEO_INDEXER_ACCOUNT_ID=<your-account-id>
VIDEO_INDEXER_LOCATION=<westus2 or your region>
VIDEO_INDEXER_SUBSCRIPTION_ID=<your-subscription-id>
VIDEO_INDEXER_RESOURCE_GROUP=<your-resource-group>
VIDEO_INDEXER_ACCOUNT_NAME=<your-account-name>
